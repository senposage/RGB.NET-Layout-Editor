<UserControl x:Class="LayoutEditor.UI.Controls.DeviceLayoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:LayoutEditor.UI.Controls"
             xmlns:s="https://github.com/canton7/Stylet"
             xmlns:rgbCore="clr-namespace:RGB.NET.Core;assembly=RGB.NET.Core"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance local:DeviceLayoutViewModel}"
             d:DesignHeight="650" d:DesignWidth="800"
             Loaded="OnLoaded">
    <UserControl.Resources>
        <s:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <ObjectDataProvider x:Key="ShapeDataProvider" MethodName="GetValues" ObjectType="{x:Type rgbCore:Shape}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="rgbCore:Shape" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="200" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="240" MinWidth="180" MaxWidth="400" />
        </Grid.ColumnDefinitions>

        <!-- Canvas area -->
        <local:LayoutCanvas x:Name="Canvas" Grid.Column="0"
                            DeviceImageSource="{Binding EditorViewModel.DeviceImage}"
                            LayoutWidth="{Binding DeviceLayout.Width}"
                            LayoutHeight="{Binding DeviceLayout.Height}" />

        <!-- Resizable splitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#D0D0D0" Cursor="SizeWE" />

        <!-- Side panel -->
        <Border Grid.Column="2" BorderBrush="#acacac" BorderThickness="0" Background="#FAFAFA">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="6">
                <StackPanel Margin="6">
                    <!-- Status bar -->
                    <Border Background="#333" Padding="6,4" Margin="-6,-6,-6,6">
                        <StackPanel>
                            <TextBlock Foreground="#aaa" FontSize="11">
                                <Run Text="LEDs:" /><Run Text="{Binding Items.Count, Mode=OneWay}" FontWeight="Bold" Foreground="White" />
                                <Run Text="  Zoom:" /><Run x:Name="ZoomText" Text="100%" FontWeight="Bold" Foreground="White" />
                            </TextBlock>
                            <TextBlock Foreground="#aaa" FontSize="11" Margin="0,2,0,0">
                                <Run Text="Selected:" /><Run x:Name="SelectedIdText" Text="None" FontWeight="Bold" Foreground="#ED4183" />
                            </TextBlock>
                            <TextBlock Foreground="#aaa" FontSize="11" Margin="0,2,0,0">
                                <Run Text="Pos:" /><Run x:Name="SelectedPosText" Text="-" Foreground="White" />
                                <Run Text="  Size:" /><Run x:Name="SelectedSizeText" Text="-" Foreground="White" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Tools -->
                    <TextBlock Text="TOOLS" FontWeight="Bold" FontSize="10" Foreground="#999" Margin="0,4,0,4" />
                    <WrapPanel Margin="0,0,0,4">
                        <CheckBox Content="Snap Grid" IsChecked="{Binding ElementName=Canvas, Path=SnapToGrid}" Margin="0,0,10,4" />
                        <CheckBox Content="Snap Neighbors" IsChecked="{Binding ElementName=Canvas, Path=SnapToNeighbors}" Margin="0,0,10,4" />
                        <CheckBox Content="Show Grid" IsChecked="{Binding ElementName=Canvas, Path=ShowGrid}" Margin="0,0,10,4" />
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Grid size:" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBox Width="50" Height="22" Text="{Binding ElementName=Canvas, Path=GridSize, UpdateSourceTrigger=LostFocus}" VerticalAlignment="Center" />
                        <TextBlock Text="mm" VerticalAlignment="Center" Margin="3,0,10,0" />
                        <TextBlock Text="Snap dist:" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBox Width="50" Height="22" Text="{Binding ElementName=Canvas, Path=SnapThreshold, UpdateSourceTrigger=LostFocus}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Grid color:" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <ComboBox Width="90" Height="22" x:Name="GridColorCombo" SelectionChanged="GridColorCombo_SelectionChanged" SelectedIndex="2">
                            <ComboBoxItem Content="White (dim)" Tag="#33FFFFFF" />
                            <ComboBoxItem Content="White (bright)" Tag="#80FFFFFF" />
                            <ComboBoxItem Content="Black" Tag="#60000000" />
                            <ComboBoxItem Content="Cyan" Tag="#80009999" />
                            <ComboBoxItem Content="Yellow" Tag="#80999900" />
                            <ComboBoxItem Content="Red" Tag="#80993333" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="Space H" Click="AutoSpaceH_Click" Padding="8,2" Margin="0,0,4,0" ToolTip="Distribute selected LEDs evenly horizontally (Ctrl+H)" />
                        <Button Content="Space V" Click="AutoSpaceV_Click" Padding="8,2" Margin="0,0,4,0" ToolTip="Distribute selected LEDs evenly vertically (Ctrl+J)" />
                        <Button Content="Undo" Click="Undo_Click" Padding="8,2" Margin="0,0,4,0" ToolTip="Ctrl+Z" />
                        <Button Content="Redo" Click="Redo_Click" Padding="8,2" ToolTip="Ctrl+Y" />
                    </StackPanel>

                    <Separator Margin="0,2,0,6" />

                    <!-- LED Properties -->
                    <TextBlock Text="LED PROPERTIES" FontWeight="Bold" FontSize="10" Foreground="#999" Margin="0,0,0,4" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="55" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="ID" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,3" />
                        <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,3" Height="24"
                                  ItemsSource="{Binding SelectedLed.AvailableLedIds}"
                                  Text="{Binding SelectedLed.InputId}" IsEditable="True">
                            <ComboBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ComboBox.ItemsPanel>
                        </ComboBox>

                        <TextBlock Text="Shape" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,3" />
                        <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,3" Height="24"
                                  ItemsSource="{Binding Source={StaticResource ShapeDataProvider}}"
                                  SelectedValue="{Binding SelectedLed.InputShape}" />

                        <TextBlock Text="X" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,3" />
                        <TextBox Grid.Row="2" Grid.Column="1" Height="22" Margin="0,0,0,3"
                                 Text="{Binding SelectedLed.InputX, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Y" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,3" />
                        <TextBox Grid.Row="3" Grid.Column="1" Height="22" Margin="0,0,0,3"
                                 Text="{Binding SelectedLed.InputY, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Width" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,3" />
                        <TextBox Grid.Row="4" Grid.Column="1" Height="22" Margin="0,0,0,3"
                                 Text="{Binding SelectedLed.InputWidth, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Height" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,3" />
                        <TextBox Grid.Row="5" Grid.Column="1" Height="22" Margin="0,0,0,3"
                                 Text="{Binding SelectedLed.InputHeight, UpdateSourceTrigger=PropertyChanged}" />

                        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Content="Apply" Command="{s:Action ApplyLed}" Padding="10,3" Margin="0,0,4,0" />
                            <Button Content="Remove" Command="{s:Action RemoveLed}" Padding="10,3" Margin="0,0,4,0" />
                        </StackPanel>
                    </Grid>

                    <Separator Margin="0,8,0,6" />

                    <!-- LED List -->
                    <TextBlock Text="LED LIST" FontWeight="Bold" FontSize="10" Foreground="#999" Margin="0,0,0,4" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="+ Before" Command="{s:Action AddLed}" CommandParameter="True" Padding="8,2" Margin="0,0,4,0" />
                        <Button Content="+ After" Command="{s:Action AddLed}" CommandParameter="False" Padding="8,2" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedLed}"
                             Height="200" Margin="0,0,0,4">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding LedLayout.Id}" FontSize="11" Padding="2,1" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Separator Margin="0,4,0,6" />

                    <!-- Help -->
                    <TextBlock Text="SHORTCUTS" FontWeight="Bold" FontSize="10" Foreground="#999" Margin="0,0,0,4" />
                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#666" LineHeight="18">
                        <Run FontWeight="Bold">Click</Run> LED to select<LineBreak/>
                        <Run FontWeight="Bold">Drag</Run> selected LED to move<LineBreak/>
                        <Run FontWeight="Bold">Ctrl+Click</Run> multi-select<LineBreak/>
                        <Run FontWeight="Bold">Arrow keys</Run> nudge selected<LineBreak/>
                        <Run FontWeight="Bold">Delete</Run> remove selected<LineBreak/>
                        <Run FontWeight="Bold">Escape</Run> deselect all<LineBreak/>
                        <Run FontWeight="Bold">G</Run> toggle grid<LineBreak/>
                        <Run FontWeight="Bold">Scroll</Run> zoom<LineBreak/>
                        <Run FontWeight="Bold">Drag background</Run> pan<LineBreak/>
                        <Run FontWeight="Bold">Ctrl+Z</Run> undo<LineBreak/>
                        <Run FontWeight="Bold">Ctrl+Y</Run> redo<LineBreak/>
                        <Run FontWeight="Bold">Ctrl+H</Run> auto-space horizontal<LineBreak/>
                        <Run FontWeight="Bold">Ctrl+J</Run> auto-space vertical<LineBreak/>
                        <Run FontWeight="Bold">Right-click</Run> context menu
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
