<Window x:Class="LayoutEditor.UI.Dialogs.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename LED" Height="120" Width="300" ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="10">
        <TextBlock Text="New LED ID:" Margin="0,0,0,4" />
        <TextBox x:Name="NameBox" Height="24" Margin="0,0,0,8" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="60" Margin="0,0,4,0" Click="OK_Click" IsDefault="True" />
            <Button Content="Cancel" Width="60" Click="Cancel_Click" IsCancel="True" />
        </StackPanel>
    </StackPanel>
</Window>
